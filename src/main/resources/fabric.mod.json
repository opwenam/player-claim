{
	"schemaVersion": 1,
	"id": "yawp-player-claim",
	"version": "${version}",
	"name": "yawp player claim",
	"description": "allows players to claim regions in Yet Another World Protector",
	"authors": [
		"opwenam"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/opwenam/player-claim"
	},
	"license": "GPL-2.0-only",
	"icon": "assets/yawp-player-claim/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.opwenam.yawpplayerclaim.YawpPlayerClaim"
		],
		"client": [
			"com.opwenam.yawpplayerclaim.client.YawpPlayerClaimClient"
		],
		"fabric-datagen": [
			"com.opwenam.yawpplayerclaim.client.YawpPlayerClaimDataGenerator"
		]
	},
	"mixins": [
		"yawp-player-claim.mixins.json",
		{
			"config": "yawp-player-claim.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*",
		"yawp": "0.6.2-beta1",
		"forgeconfigapiport": "*"
	}
}